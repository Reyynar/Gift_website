        </button>

    </section>

    <!-- SCREEN 2 -->
    <section id="screen2" class="screen hidden">

        <div class="teddy">
            🧸
        </div>

        <h1>Surprise!! ❤️</h1>

        <div class="letter">

            <h2>Dear SAAD,</h2>

            <p>

                I wanted to send you a little surprise.

                I hope today brings you happiness,
                lots of smiles,
                and reminds you that you're appreciated.

                Thank you for being an amazing person.

                💖

            </p>

        </div>

        <button id="smileBtn">
            Continue 😊
        </button>

    </section>

    <!-- SCREEN 3 -->
    <section id="screen3" class="screen hidden">

        <h1>Did this make you smile? 😊</h1>

        <div>

            <button id="yesBtn">
                YES 😄
            </button>

            <button id="noBtn">
                NO 😅
            </button>

        </div>

    </section>

    <!-- SCREEN 4 -->
    <section id="screen4" class="screen hidden">

        <h1 id="answerText"></h1>

        <button id="surpriseBtn">
            ✨ One More Surprise
        </button>

    </section>

    <!-- SCREEN 5 -->
    <section id="screen5" class="screen hidden">

        <h1>🤗 One Last Hug?</h1>

        <button id="hugBtn">
            Send Hug ❤️
        </button>

    </section>

    <!-- FINAL SCREEN -->
    <section id="screen6" class="screen hidden">

        <h1 class="finalTitle">
            ❤️ Sending the Biggest Virtual Hug ❤️
        </h1>

        <h2>
            To
        </h2>

        <h1 style="font-size:70px;">
            SAAD
        </h1>

        <h2>
            From
        </h2>

        <h1 style="font-size:60px;">
            YOUR BOSS 💖
        </h1>

        <p style="margin-top:30px;font-size:24px;">
            You deserve all the happiness in the world.
        </p>

    </section>

    <!-- Effects -->

    <div id="flowers"></div>

    <div id="stars"></div>

    <div id="sparkles"></div>

    <div id="hearts"></div>

    <canvas id="confetti"></canvas>

</div>

<script src="script.js"></script>
/* ===========================
   GLOBAL
=========================== */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
}

body{
    font-family:'Poppins',sans-serif;
    overflow:hidden;
    background:linear-gradient(180deg,#ff9ecf,#ffd6ec,#fff7fd);
    width:100vw;
    height:100vh;
}

.hidden{
    display:none !important;
}

.center{
    display:flex;
    justify-content:center;
    align-items:center;
}

/* ===========================
   MAIN CONTAINER
=========================== */

#game{
    position:relative;
    width:100vw;
    height:100vh;
    overflow:hidden;
}

.screen{
    position:absolute;
    width:100%;
    height:100%;
    display:flex;
    justify-content:center;
    align-items:center;
    flex-direction:column;
}

/* ===========================
   BACKGROUND
=========================== */

.backgroundGlow{
    position:absolute;
    inset:0;
    background:
    radial-gradient(circle at top,#ffffff66 0%,transparent 45%),
    radial-gradient(circle at bottom,#ffe2f166 0%,transparent 55%);
    animation:glow 8s infinite alternate;
}

@keyframes glow{

0%{
filter:brightness(1);
}

100%{
filter:brightness(1.3);
}

}

/* ===========================
   GIFT BOX
=========================== */

.giftBox{
    width:230px;
    height:230px;
    position:relative;
    cursor:pointer;
    transition:.4s;
    animation:giftBounce 2s infinite;
}

.giftBox:hover{
    transform:scale(1.08);
}

.giftBase{
    width:230px;
    height:160px;
    background:#ff4f8a;
    border-radius:12px;
    position:absolute;
    bottom:0;
    box-shadow:0 15px 30px rgba(0,0,0,.2);
}

.giftLid{
    width:240px;
    height:60px;
    background:#ff73a4;
    position:absolute;
    left:-5px;
    top:20px;
    border-radius:10px;
    transition:.8s;
}

.ribbonVertical{
    position:absolute;
    width:30px;
    height:230px;
    background:white;
    left:100px;
}

.ribbonHorizontal{
    position:absolute;
    width:230px;
    height:30px;
    background:white;
    top:95px;
}

.bow{
    position:absolute;
    top:-12px;
    left:82px;
    font-size:60px;
}

@keyframes giftBounce{

0%{
transform:translateY(0px);
}

50%{
transform:translateY(-18px);
}

100%{
transform:translateY(0px);
}

}

/* ===========================
   LOCK
=========================== */

.lock{
    margin-top:35px;
    font-size:40px;
    animation:shakeLock 2s infinite;
}

@keyframes shakeLock{

0%,100%{
transform:rotate(0);
}

20%{
transform:rotate(10deg);
}

40%{
transform:rotate(-10deg);
}

60%{
transform:rotate(8deg);
}

80%{
transform:rotate(-8deg);
}

}

/* ===========================
   BUTTONS
=========================== */

button{

padding:15px 35px;
margin-top:25px;
border:none;
border-radius:40px;
font-size:18px;
cursor:pointer;
background:white;
color:#ff4b91;
font-weight:bold;
transition:.3s;
box-shadow:0 8px 20px rgba(0,0,0,.15);

}

button:hover{

transform:scale(1.1);

background:#ff4b91;
color:white;

}

/* ===========================
   TEDDY
=========================== */

.teddy{

font-size:180px;
animation:teddyJump 1.6s infinite;

}

@keyframes teddyJump{

0%{
transform:translateY(0);
}

50%{
transform:translateY(-25px);
}

100%{
transform:translateY(0);
}

}

/* ===========================
   LETTER
=========================== */

.letter{

width:650px;
max-width:90%;
padding:35px;
background:white;
border-radius:20px;
box-shadow:0 15px 40px rgba(0,0,0,.2);

line-height:1.8;

color:#555;

animation:fadeUp 1s;

}

.letter h2{

margin-bottom:15px;
color:#ff4f8a;

}

@keyframes fadeUp{

from{

opacity:0;
transform:translateY(40px);

}

to{

opacity:1;
transform:translateY(0);

}

}

</body>
</html>
/* ===================================
   FLOWERS
=================================== */

#flowers{
position:absolute;
top:0;
left:0;
width:100%;
height:100%;
pointer-events:none;
overflow:hidden;
}

.flower{
position:absolute;
font-size:28px;
animation:flowerFall linear forwards;
opacity:.95;
}

@keyframes flowerFall{

0%{
transform:translateY(-120px) rotate(0deg);
opacity:0;
}

15%{
opacity:1;
}

100%{
transform:translateY(120vh) rotate(720deg);
opacity:0;
}

}

/* ===================================
   STARS
=================================== */

#stars{
position:absolute;
top:0;
left:0;
width:100%;
height:100%;
pointer-events:none;
overflow:hidden;
}

.star{
position:absolute;
color:white;
font-size:22px;
text-shadow:
0 0 8px white,
0 0 18px white,
0 0 30px white;
animation:starFall linear forwards;
}

@keyframes starFall{

0%{
transform:translateY(-120px) scale(.3);
opacity:0;
