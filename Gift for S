<body>

<div id="game">

    <div class="backgroundGlow"></div>

    <!-- SCREEN 1 -->
    <section id="screen1" class="screen">

        <h1>🎁 A Special Gift For You 🎁</h1>

        <p style="margin:20px;">
            Unlock the gift to see what's inside!
