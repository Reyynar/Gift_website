/* ==========================================
   GIFT FOR SAAD ❤️
   script.js - Chunk 1
========================================== */

const screen1 = document.getElementById("screen1");
const screen2 = document.getElementById("screen2");
const screen3 = document.getElementById("screen3");
const screen4 = document.getElementById("screen4");
const screen5 = document.getElementById("screen5");
const screen6 = document.getElementById("screen6");

const gift = document.getElementById("gift");

const unlockBtn = document.getElementById("unlockBtn");
const smileBtn = document.getElementById("smileBtn");
const yesBtn = document.getElementById("yesBtn");
const noBtn = document.getElementById("noBtn");
const surpriseBtn = document.getElementById("surpriseBtn");
const hugBtn = document.getElementById("hugBtn");

const flowers = document.getElementById("flowers");
const stars = document.getElementById("stars");
const sparkles = document.getElementById("sparkles");
const hearts = document.getElementById("hearts");

const answerText = document.getElementById("answerText");

/* ============================
   OPEN GIFT
============================ */

unlockBtn.onclick = function(){

gift.classList.add("pop");

createFlowers();
createStars();
createSparkles();

setTimeout(function(){

screen1.classList.add("hidden");

screen2.classList.remove("hidden");

screen2.classList.add("fadeIn");

},900);

}

/* ============================
   NEXT SCREEN
============================ */

smileBtn.onclick=function(){

screen2.classList.add("hidden");

screen3.classList.remove("hidden");

screen3.classList.add("fadeIn");

}

/* ============================
   YES BUTTON
============================ */

yesBtn.onclick=function(){

screen3.classList.add("hidden");

screen4.classList.remove("hidden");

answerText.innerHTML="😊 I knew it! That makes me happy ❤️";

createSparkles();

}

/* ============================
   NO BUTTON
============================ */

noBtn.onclick=function(){

screen3.classList.add("hidden");

screen4.classList.remove("hidden");

answerText.innerHTML="😂 Nice try! I'm still counting that as a smile!";

createSparkles();

}

/* ============================
   ONE MORE SURPRISE
============================ */

surpriseBtn.onclick=function(){

screen4.classList.add("hidden");

screen5.classList.remove("hidden");

createFlowers();

createStars();

}

/* ============================
   SEND HUG
============================ */

hugBtn.onclick=function(){

screen5.classList.add("hidden");

screen6.classList.remove("hidden");

createHearts();

createFlowers();

createStars();

createSparkles();

}

/* ============================
   FLOWERS
============================ */

function createFlowers(){

for(let i=0;i<120;i++){

let flower=document.createElement("div");

flower.className="flower";

flower.innerHTML=["🌸","🌹","🌺","🌼","🌷"][Math.floor(Math.random()*5)];

flower.style.left=Math.random()*100+"%";

flower.style.animationDuration=(4+Math.random()*5)+"s";

flower.style.animationDelay=Math.random()*2+"s";

flower.style.fontSize=(20+Math.random()*25)+"px";

flowers.appendChild(flower);

setTimeout(()=>{

flower.remove();

},9000);

}

}

/* ============================
   STARS
============================ */

function createStars(){

for(let i=0;i<140;i++){

let star=document.createElement("div");

star.className="star";

star.innerHTML="⭐";

star.style.left=Math.random()*100+"%";

star.style.animationDuration=(3+Math.random()*4)+"s";

star.style.animationDelay=Math.random()*2+"s";

star.style.fontSize=(12+Math.random()*20)+"px";

stars.appendChild(star);

setTimeout(()=>{

star.remove();

},8000);

}

}
/* ==========================================
   script.js - Chunk 2 (Append to Chunk 1)
========================================== */

/* ============================
   SPARKLES
============================ */

function createSparkles() {

    for (let i = 0; i < 180; i++) {

        let sparkle = document.createElement("div");

        sparkle.className = "sparkle";

        sparkle.style.left = Math.random() * 100 + "%";
        sparkle.style.top = Math.random() * 100 + "%";

        sparkle.style.animationDelay =
            Math.random() * 2 + "s";

        sparkle.style.animationDuration =
            (1 + Math.random() * 2) + "s";

        sparkles.appendChild(sparkle);

        setTimeout(() => {

            sparkle.remove();

        }, 4000);

    }

}

/* ============================
   HEARTS
============================ */

function createHearts() {

    setInterval(() => {

        let heart = document.createElement("div");

        heart.className = "heart";

        heart.innerHTML =
            ["❤️", "💖", "💕", "💗", "💓"][Math.floor(Math.random() * 5)];

        heart.style.left = Math.random() * 100 + "%";

        heart.style.fontSize =
            (18 + Math.random() * 35) + "px";

        heart.style.animationDuration =
            (5 + Math.random() * 4) + "s";

        hearts.appendChild(heart);

        setTimeout(() => {

            heart.remove();

        }, 9000);

    }, 150);

}

/* ============================
   CONTINUOUS FLOWERS
============================ */

setInterval(() => {

    if (!screen6.classList.contains("hidden")) {

        createFlowers();

    }

}, 3500);

/* ============================
   CONTINUOUS STARS
============================ */

setInterval(() => {

    if (!screen6.classList.contains("hidden")) {

        createStars();

    }

}, 2500);

/* ============================
   CONTINUOUS SPARKLES
============================ */

setInterval(() => {

    if (!screen6.classList.contains("hidden")) {

        createSparkles();

    }

}, 1800);

/* ============================
   TEDDY BOUNCE
============================ */

const teddy = document.querySelector(".teddy");

if (teddy) {

    setInterval(() => {

        teddy.classList.add("teddyShow");

        setTimeout(() => {

            teddy.classList.remove("teddyShow");

        }, 1000);

    }, 2500);

}

/* ============================
   CONFETTI
============================ */

const canvas = document.getElementById("confetti");
const ctx = canvas.getContext("2d");

canvas.width = window.innerWidth;
canvas.height = window.innerHeight;

const confetti = [];

function startConfetti() {

    for (let i = 0; i < 300; i++) {

        confetti.push({

            x: Math.random() * canvas.width,

            y: Math.random() * canvas.height,

            size: 5 + Math.random() * 10,

            speed: 2 + Math.random() * 5,

            color:
                `hsl(${Math.random() * 360},100%,60%)`

        });

    }

}

function animateConfetti() {

    ctx.clearRect(0, 0, canvas.width, canvas.height);

    confetti.forEach(c => {

        ctx.fillStyle = c.color;

        ctx.fillRect(c.x, c.y, c.size, c.size);

        c.y += c.speed;

        if (c.y > canvas.height) {

            c.y = -20;

            c.x = Math.random() * canvas.width;

        }

    });

    requestAnimationFrame(animateConfetti);

}

startConfetti();
animateConfetti();

/* ============================
   WINDOW RESIZE
============================ */

window.addEventListener("resize", () => {

    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

});

/* ==========================================
   END OF SCRIPT
========================================== */
