<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>💖 Surprise</title>
  <link rel="stylesheet" href="style.css"/>
</head>
<body>

<!-- STEP 1: YES / NO -->
<div class="screen active" id="screen1">
  <h1>Will you continue? 💖</h1>

  <div class="btn-row">
    <button id="yesBtn">💖 Yes</button>
    <button id="noBtn">🙈 No</button>
  </div>
</div>

<!-- POPUP -->
<div id="popup" class="popup hidden">
  🥺 I promise you’re going to love it.
</div>

<!-- STEP 2: ENVELOPE -->
<div class="screen" id="screen2">
  <div class="envelope" id="envelope">✉️</div>
  <p>Tap me.</p>
</div>

<!-- STEP 3: GIFT -->
<div class="screen" id="screen3">
  <div class="gift" id="gift">🎁</div>
</div>

<!-- MAGIC -->
<div id="magic" class="magic hidden"></div>

<!-- LETTER -->
<div class="screen" id="screen4">
  <div class="card">
    <h2>💌 Dear Saad,</h2>
    <p id="letter"></p>
  </div>
</div>

<!-- FINAL -->
<div class="screen" id="screen5">
  <div class="card">
    <h2>Wait… 😂</h2>
    <button id="finalBtn">Click me 😂</button>
    <p id="finalText"></p>
  </div>
</div>

<script src="script.js"></script>
</body>
</html>
body {
  margin: 0;
  font-family: Arial;
  overflow: hidden;
  background: linear-gradient(135deg,#ff9a9e,#fad0c4,#a18cd1);
  background-size: 400% 400%;
  animation: bg 10s infinite;
  color: white;
  text-align: center;
}

@keyframes bg {
  0%{background-position:0% 50%}
  50%{background-position:100% 50%}
  100%{background-position:0% 50%}
}

.screen {
  display: none;
  height: 100vh;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}

.screen.active {
  display: flex;
}

button {
  padding: 15px 25px;
  margin: 10px;
  border: none;
  border-radius: 20px;
  cursor: pointer;
  font-size: 18px;
}

#yesBtn {
  background: #ff4d6d;
  color: white;
  transition: 0.3s;
}

#noBtn {
  background: #555;
  color: white;
  position: relative;
}

.popup {
  position: fixed;
  top: 20px;
  left: 50%;
  transform: translateX(-50%);
  background: white;
  color: black;
  padding: 10px 20px;
  border-radius: 15px;
}

.hidden { display: none; }

/* Envelope */
.envelope {
  font-size: 80px;
  cursor: pointer;
  animation: float 2s infinite;
}

@keyframes float {
  0%,100%{transform:translateY(0)}
  50%{transform:translateY(-10px)}
}

/* Gift */
.gift {
  font-size: 100px;
  animation: shake 1s infinite;
  cursor: pointer;
}

@keyframes shake {
  0%,100%{transform:rotate(0)}
  50%{transform:rotate(5deg)}
}

/* Magic overlay */
.magic {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.2);
}

/* Card */
.card {
  background: rgba(255,255,255,0.15);
  padding: 20px;
  border-radius: 20px;
  backdrop-filter: blur(10px);

}
const screens = {
  s1: document.getElementById("screen1"),
  s2: document.getElementById("screen2"),
  s3: document.getElementById("screen3"),
  s4: document.getElementById("screen4"),
  s5: document.getElementById("screen5"),
};

function show(screen) {
  Object.values(screens).forEach(s => s.classList.remove("active"));
  screen.classList.add("active");
}

// YES / NO
const yesBtn = document.getElementById("yesBtn");
const noBtn = document.getElementById("noBtn");
const popup = document.getElementById("popup");

yesBtn.onclick = () => show(screens.s2);

noBtn.addEventListener("mouseenter", () => {
  noBtn.style.left = Math.random() * 200 - 100 + "px";
  noBtn.style.top = Math.random() * 100 + "px";

  yesBtn.style.transform = "scale(1.3)";
  popup.classList.remove("hidden");

  setTimeout(() => popup.classList.add("hidden"), 2000);
});

// ENVELOPE
document.getElementById("envelope").onclick = () => {
  show(screens.s3);
};

// GIFT
document.getElementById("gift").onclick = () => {
  document.getElementById("magic").classList.remove("hidden");
  show(screens.s4);
  typeLetter();
};

// LETTER TYPE EFFECT
const text = `Thank you for being such a wonderful person.

I wanted to make something that would hopefully make you smile today.

You deserve happiness, laughter, and every beautiful thing life has to offer.

I hope every time you think of this, you remember how appreciated you are.

❤️

Love,
Your Boss`;

let i = 0;
function typeLetter() {
  const el = document.getElementById("letter");
  el.innerHTML = "";
  i = 0;

  const interval = setInterval(() => {
    el.innerHTML += text[i];
    i++;
    if (i >= text.length) clearInterval(interval);
  }, 30);
}

// FINAL
document.getElementById("finalBtn").onclick = () => {
  document.getElementById("finalText").innerText =
    "You smiled, didn’t you? 😏";
  show(screens.s5);
};
